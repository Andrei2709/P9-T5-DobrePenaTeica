@model ProiectBanking.Models.Client
@{
    ViewData["Title"] = "My Profile";
    var transactions = ViewBag.Transactions as IEnumerable<ProiectBanking.Models.Transaction>;
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Welcome back, @Model.FirstName!</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-bold"><i class="bi bi-check-circle"></i> @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger fw-bold"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]</div>
    }

    <div class="row">
        <!-- COL 1: Accounts and Transfer -->
        <div class="col-lg-6 mb-4">

            <div class="card shadow-sm border-0 mb-4" style="border-radius:15px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-bank mb-3"><i class="bi bi-wallet2 me-2"></i>My Accounts</h5>
                    @if (Model.BankAccounts != null && Model.BankAccounts.Any())
                    {
                        foreach (var acc in Model.BankAccounts)
                        {
                            <div class="p-3 mb-2 bg-light rounded d-flex justify-content-between align-items-center shadow-sm">
                                <div>
                                    <span class="badge bg-primary">@acc.AccountType</span>
                                    <strong class="d-block mt-1 font-monospace text-muted">@acc.IBAN</strong>
                                </div>
                                <h5 class="fw-bold text-success mb-0">@acc.Balance.ToString("N2") @acc.Currency</h5>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">You have no active accounts.</p>
                    }
                </div>
            </div>

            <!-- TRANSFER FORM -->
            <div class="card shadow-sm border-0" style="border-radius:15px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-bank mb-3"><i class="bi bi-send me-2"></i>Send Money</h5>
                    <form asp-controller="Profile" asp-action="MakeTransfer" method="post">
                        <div class="mb-3">
                            <label class="form-label small text-muted">From account:</label>
                            <select class="form-select bg-light border-0" name="sourceAccountId" required>
                                @foreach (var acc in Model.BankAccounts)
                                {
                                    <option value="@acc.Id">@acc.IBAN (@acc.Balance.ToString("N2") @acc.Currency)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">To IBAN:</label>
                            <input type="text" class="form-control bg-light border-0" name="destinationIban" required placeholder="RO99BANK..." />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Amount:</label>
                            <input type="number" step="0.01" min="1" class="form-control bg-light border-0" name="amount" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small text-muted">Description:</label>
                            <input type="text" class="form-control bg-light border-0" name="description" placeholder="e.g., Rent payment" />
                        </div>
                        <button type="submit" class="btn btn-bank w-100 fw-bold py-2 shadow-sm">Send Money</button>
                    </form>
                </div>
            </div>

        </div>

        <!-- COL 2: Transaction History -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100" style="border-radius:15px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-bank mb-3"><i class="bi bi-clock-history me-2"></i>Recent Transactions</h5>
                    @if (transactions != null && transactions.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var trx in transactions)
                            {
                                // Verificăm dacă clientul e cel care a trimis sau cel care a primit
                                bool isOutgoing = Model.BankAccounts.Any(a => a.Id == trx.SourceAccountId) && trx.TransactionType != "Deposit";

                                <li class="list-group-item px-0 py-3 border-bottom">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <strong class="d-block">@trx.Description</strong>

                                            <!-- Către cine vs. De la cine -->
                                            @if (isOutgoing)
                                            {
                                                <small class="text-muted">To: @trx.DestinationInfo</small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">
                                                    From: @(trx.SourceAccount != null ? trx.SourceAccount.IBAN : "Branch Deposit")
                                                </small>
                                            }

                                            <br />
                                            @if (trx.Status == "Pending Approval")
                                            {
                                                <span class="badge bg-warning text-dark mt-1">Pending (Security)</span>
                                            }
                                            else if (trx.Status == "Rejected")
                                            {
                                                <span class="badge bg-danger mt-1">Rejected</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success mt-1">Completed</span>
                                            }
                                        </div>
                                        <div class="text-end">
                                            <!-- SUMA (Cu Roșu sau Verde) -->
                                            @if (isOutgoing)
                                            {
                                                <strong class="text-danger">-@trx.Amount.ToString("N2") @trx.Currency</strong>
                                            }
                                            else
                                            {
                                                <strong class="text-success">+@trx.Amount.ToString("N2") @trx.Currency</strong>
                                            }
                                            <br />
                                            <small class="text-muted">@trx.TransactionDate.ToString("dd MMM HH:mm")</small>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No recent transactions.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>