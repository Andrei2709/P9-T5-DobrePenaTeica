@model ProiectBanking.Models.Client
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-bank mb-4">Edit Profile Settings</h2>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4">@TempData["Error"]</div>
            }

            <form asp-controller="Profile" asp-action="Edit" method="post">

                <div class="card card-bank p-4 shadow-sm mb-4 border-0" style="border-radius: 15px;">
                    <h5 class="fw-bold text-bank mb-4">Personal Information</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">First Name</label>
                            <input type="text" name="FirstName" class="form-control" value="@Model.FirstName" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Last Name</label>
                            <input type="text" name="LastName" class="form-control" value="@Model.LastName" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Phone Number</label>
                        <input type="text" name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" />
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-bold small text-muted">Address</label>
                        <input type="text" name="Address" class="form-control" value="@Model.Address" placeholder="Enter your address..." />
                    </div>
                </div>

                <div class="card card-bank p-4 shadow-sm mb-4 border-0" style="border-radius: 15px; background-color: #fdfcfe;">
                    <h5 class="fw-bold text-bank mb-4">Security</h5>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Current Password (Required only for password change)</label>
                        <input type="password" name="OldPassword" class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">New Password</label>
                            <input type="password" name="NewPassword" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Confirm New Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-bank px-5 fw-bold shadow-sm">Update Profile</button>
                </div>
            </form>
        </div>
    </div>
</div>