@{
    ViewData["Title"] = "Log In";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 mt-5" style="border-radius: 15px;">
                <div class="card-header bg-white text-center pb-0 border-0 pt-5">
                    <h3 class="fw-bold text-bank">Welcome Back</h3>
                    <p class="text-muted small">Enter your credentials to access your account</p>
                </div>
                <div class="card-body p-4 p-md-5 pt-0">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger shadow-sm border-0 border-start border-5 border-danger p-3 mb-4 small fw-bold">
                            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
                        </div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success shadow-sm border-0 border-start border-5 border-success p-3 mb-4 small fw-bold">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        </div>
                    }
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger p-3 mb-4 small">
                            <div asp-validation-summary="All" class="text-danger mb-0"></div>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">

                        <div class="form-floating mb-3">
                            <input type="email" class="form-control bg-light border-0" id="inputEmail" name="Email" placeholder="name@example.com" required />
                            <label for="inputEmail" class="text-muted small">Email address</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input type="password" class="form-control bg-light border-0" id="inputPassword" name="Password" placeholder="Password" required />
                            <label for="inputPassword" class="text-muted small">Password</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-bank btn-lg fw-bold shadow-sm py-3" style="border-radius: 10px;">Log In</button>
                        </div>
                    </form>

                </div>
                <div class="card-footer text-center py-4 bg-white border-0" style="border-bottom-left-radius: 15px; border-bottom-right-radius: 15px;">
                    <p class="small mb-0 text-muted">
                        Don't have an account?
                        <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold text-bank">Sign up here!</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>