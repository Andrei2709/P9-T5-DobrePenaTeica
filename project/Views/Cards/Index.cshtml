@model IEnumerable<ProiectBanking.Models.Card>
@{
    ViewData["Title"] = "My Cards";
    var accounts = ViewBag.Accounts as List<ProiectBanking.Models.BankAccount>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-bank">Manage My Cards</h2>
        <button class="btn btn-bank shadow-sm fw-bold" data-bs-toggle="modal" data-bs-target="#issueCardModal">
            <i class="bi bi-plus-lg me-2"></i>Issue New Card
        </button>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var card in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card p-4 shadow-lg @(card.IsBlocked ? "opacity-50" : "")"
                         style="background: linear-gradient(135deg, #2c3e50 0%, #000000 100%); color: white; border-radius: 20px; border: none; min-height: 240px; position: relative;">

                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <span class="fw-bold fs-5">@card.CardType</span>
                            <i class="bi bi-cpu-fill fs-2 text-warning"></i>
                        </div>

                        <div class="mb-4 text-center">
                            <h4 class="mb-0 fw-bold" style="letter-spacing: 3px; font-family: 'Courier New', monospace;">
                                @card.CardNumber
                            </h4>
                        </div>

                        <div class="d-flex justify-content-between mt-auto small">
                            <div>
                                <label class="d-block opacity-75 text-uppercase" style="font-size: 0.6rem;">Card Holder</label>
                                <span class="fw-bold">@card.CardHolderName</span>
                            </div>
                            <div class="text-center">
                                <label class="d-block opacity-75 text-uppercase" style="font-size: 0.6rem;">Expires</label>
                                <span class="fw-bold">@card.ExpiryDate</span>
                            </div>
                            <div class="text-end text-warning">
                                <label class="d-block opacity-75 text-uppercase" style="font-size: 0.6rem;">CVV</label>
                                <span class="fw-bold">@card.CVV</span>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <form asp-action="ToggleBlock" method="post" class="flex-fill">
                                <input type="hidden" name="cardId" value="@card.Id" />
                                <button type="submit" class="btn btn-sm w-100 @(card.IsBlocked ? "btn-warning" : "btn-outline-light") fw-bold">
                                    @(card.IsBlocked ? "Unblock" : "Block")
                                </button>
                            </form>

                            <form asp-action="DeleteCard" method="post" class="flex-fill" onsubmit="return confirm('Are you sure you want to permanently delete this card?');">
                                <input type="hidden" name="cardId" value="@card.Id" />
                                <button type="submit" class="btn btn-sm btn-danger w-100 fw-bold">
                                    Remove
                                </button>
                            </form>
                        </div>
                    </div>
                    <p class="text-center mt-2 small text-muted">
                        Linked to: <strong>@card.Account.Currency</strong> (@card.Account.IBAN)
                    </p>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">No cards found. Issue one from an active account.</p>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="issueCardModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <form asp-action="IssueCard" method="post">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold text-bank">Request New Card</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">SELECT ACCOUNT</label>
                        <select name="BankAccountId" class="form-select bg-light border-0 py-2" required>
                            @if (accounts != null)
                            {
                                foreach (var acc in accounts)
                                {
                                    <option value="@acc.Id">@acc.Currency (@acc.IBAN)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">CARD TYPE</label>
                        <select name="CardType" class="form-select bg-light border-0 py-2">
                            <option value="Visa">Visa Debit</option>
                            <option value="Mastercard">Mastercard</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" class="btn btn-bank w-100 py-2 fw-bold">Issue Card</button>
                </div>
            </form>
        </div>
    </div>
</div>