@model IEnumerable<ProiectBanking.Models.BankAccount>
@{
    ViewData["Title"] = "Transfers";
}

<div class="row mt-4 justify-content-center">
    <div class="col-md-8">
        <h2 class="fw-bold text-bank mb-4">New Transfer</h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger shadow-sm border-0 border-start border-5 border-danger">
                <strong>Error:</strong> @TempData["Error"]
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success shadow-sm border-0 border-start border-5 border-success">
                <strong>Success:</strong> @TempData["Success"]
            </div>
        }

        <div class="card card-bank p-4 shadow-sm">
            <form asp-controller="Transfers" asp-action="SubmitTransfer" method="post">

                <div class="mb-4">
                    <label class="form-label fw-semibold text-muted text-uppercase small">From Account</label>
                    <select name="SourceAccountId" class="form-select bg-light" required>
                        <option value="" disabled selected>Select an account...</option>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var account in Model)
                            {
                                <option value="@account.Id">
                                    @account.Currency Account (@account.IBAN) - Balance: @account.Balance.ToString("N2") @account.Currency
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold text-muted text-uppercase small">To IBAN</label>
                    <input type="text" name="DestinationIban" class="form-control bg-light" placeholder="RO99BANK..." required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold text-muted text-uppercase small">Amount</label>
                        <input type="number" name="Amount" step="0.01" min="0.01" class="form-control bg-light" placeholder="0.00" required />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold text-muted text-uppercase small">Payment Details</label>
                        <input type="text" name="Description" class="form-control bg-light" placeholder="e.g. Rent, Invoice #123" required />
                    </div>
                </div>

                <div class="text-end mt-2">
                    <button type="reset" class="btn btn-outline-secondary px-4 me-2">Clear</button>
                    <button type="submit" class="btn btn-bank px-5 fw-bold shadow-sm">Send Money</button>
                </div>

            </form>
        </div>
    </div>
</div>